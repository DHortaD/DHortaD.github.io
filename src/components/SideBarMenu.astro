---
const { sideBarActiveItemID } = Astro.props;
// Active link becomes Charcoal with Sage text (inverted)
const activeClass = "bg-[#1A1A1A] text-[#A3C6C4] font-bold"; 
---

<ul class="menu grow shrink menu-md overflow-y-auto">
    <li><a class="py-3 text-base hover:bg-[#1A1A1A] hover:text-[#A3C6C4] transition-all" id="home" href="/">Home</a></li>
    <li><a class="py-3 text-base hover:bg-[#1A1A1A] hover:text-[#A3C6C4] transition-all" id="projects" href="/projects">Projects</a></li>
    <li><a class="py-3 text-base hover:bg-[#1A1A1A] hover:text-[#A3C6C4] transition-all" id="blog" href="/blog/">Blog</a></li>
    <li><a class="py-3 text-base hover:bg-[#1A1A1A] hover:text-[#A3C6C4] transition-all" id="cv" href="/cv">CV</a></li>
</ul>

<style>
    /* Default menu text color (Dark for light sidebar) */
    .menu a { color: #1A1A1A; }
</style>
