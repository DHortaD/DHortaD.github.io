---
const { title, subtitle } = Astro.props;
---

<div class="flex">
  <div class="education__time">
    <span class="w-4 h-4 bg-[#A3C6C4] block rounded-full mt-1"></span>
    
    <span class="education__line bg-[#A3C6C4] block h-full w-[2px] translate-x-[7px] opacity-50"></span>
  </div>
  
  <div class="experience__data bd-grid px-5">
    <h3 class="font-semibold mb-1 text-[#F8FAFC]">{title}</h3>
    <span class="font-light text-sm text-[#A3C6C4]">{subtitle}</span>
    <div class="my-2 text-justify text-slate-300">
      <slot />
    </div>
  </div>
</div>
