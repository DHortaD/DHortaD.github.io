---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Blog" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects Header</div>
  </div>

  <HorizontalCard
    title="Notes on statistics taken from the book ``elements of statistical learning'' by Hastie, Tibshirani, and Friedman"
    img="/stats.png"
    desc="These are notes I wrote for my own understanding. Use them if you think they are useful"
    url="https://github.com/DHortaD/Statistics-notes/blob/main/Elements-Of-Statistical-Learning/Notes-Elements_of_statistical_learning.pdf"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Classifying Galaxy Images with a neural-network written in PyTorch"
    img="/galaxyimages.png"
    desc="An example of how you can write a convolutional neural-network in PyTorch to classify 2D galaxy images. There is a pdf describing this exercise and associated code to replicate the results"
    url="https://github.com/DHortaD/blog-posts/tree/main/galaxy-classification-PyTorch"
  />
</BaseLayout>
