---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Visualisations" sideBarActiveItemID="visualisations">
  <div class="pb-12 mt-5 bg-[#2D463E] border border-[#3D5A4F] p-8 rounded-2xl shadow-xl text-[#F8FAFC]">
    <div class="flex flex-col md:flex-row gap-8">
      <div class="flex-1">
        <h1 class="text-5xl font-bold mb-4">Visualisations</h1>
        <p class="text-lg opacity-90 leading-relaxed">
          The following visualizations and movies are free to use and available via the 
          <span class="underline decoration-[#A3C6C4]">Creative Commons CC-BY-SA license</span>. 
          In short, if you use these, please (1) acknowledge <strong>“D. Horta”</strong>, 
          and (2) if you re-distribute any of this material, you must carry along this license.
        </p>
      </div>
    </div>
  </div>

  <div class="mt-12 space-y-10">
    <section>
      <h2 class="text-3xl font-bold mb-6 border-b border-[#2D463E] pb-2 text-[#A3C6C4]">
        Assembly history of a Milky Way-mass galaxy
      </h2>
      <p class="mb-8 text-slate-300 leading-relaxed">
        The two movies below were created using the <strong>FIRE-2 cosmological simulations (m12m)</strong>, 
        and show the distribution of star particles belonging to different "building-blocks" 
        (i.e., accreted galaxies) consumed by a Milky Way-mass galaxy as a function of time. 
        The GIFs show the merging process in spatial coordinates (X-Z) and in the 
        energy-angular momentum diagram. Each merger is labelled with a different colour.
      </p>

      <div class="flex flex-col md:flex-row gap-6 justify-center items-center">
        <div class="bg-[#1A1A1A] p-2 rounded-lg border border-[#3D5A4F] shadow-lg">
           <img src="/XZ-mergers-m12m.gif" alt="X-Z Mergers" class="rounded w-full max-w-[450px] h-auto" />
           <p class="text-center text-xs mt-2 text-[#A3C6C4]">Spatial Coordinates (X-Z)</p>
        </div>
        <div class="bg-[#1A1A1A] p-2 rounded-lg border border-[#3D5A4F] shadow-lg">
           <img src="/ELz-mergers-m12m.gif" alt="Energy-Angular Momentum" class="rounded w-full max-w-[450px] h-auto" />
           <p class="text-center text-xs mt-2 text-[#A3C6C4]">Energy-Angular Momentum Diagram</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
